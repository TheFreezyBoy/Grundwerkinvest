    "lucide-react": "0.487.0",
    "motion": "12.23.24",
    "next": "16.2.0",
    "next-themes": "0.4.6",
    "payload": "3.80.0",
    "postcss": "^8.5.8",
    "react": "19.2.4",
    "react-day-picker": "8.10.1",
